# Serverseitige Datenhaltung
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# GitHub: optional für private Repositories und höhere Rate Limits
GITHUB_TOKEN=

# AI Review: vorhandene Claude-CLI-Anmeldung wird standardmäßig genutzt
CLAUDE_REVIEW_MODEL=sonnet
# PRACTIO_AI_REVIEW_MODE=mock
# PRACTIO_REVIEW_REPO=/home/ole/epikur-workspaces/epikur-dashboard

# Bestehende Server-Konfiguration
SESSION_SECRET=
WEBSSH_PASSWORD=

# Automatischer Login der isolierten Epikur-Preview
PREVIEW_TEST_EMAIL=
PREVIEW_TEST_PASSWORD=

# Optional, falls die CLIs nicht unter /usr/bin installiert sind
CLAUDE_BIN=/usr/bin/claude
CODEX_BIN=/usr/bin/codex
